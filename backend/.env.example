# Application
APP_NAME=mortgageboss-ai
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# Database (PostgreSQL with asyncpg driver)
# Use the credentials from docker-compose.yml for local development
DATABASE_URL=postgresql+asyncpg://mortgageboss:mortgageboss_dev_password@localhost:5432/mortgageboss_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis (for Celery broker and caching)
REDIS_URL=redis://localhost:6379/0

# Anthropic API (LP-37)
# REQUIRED for AI features (classification LP-38, extraction LP-39). The app refuses
# to start without it; the missing-key error for an actual AI *call* fires at call time.
# Tests mock the client, so they never make a real call (CI uses a dummy value).
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here  # pragma: allowlist secret
# Model identifiers — CONFIGURATION to VERIFY against current Anthropic docs (they change).
ANTHROPIC_MODEL_CLASSIFICATION=claude-haiku-4-5
ANTHROPIC_MODEL_EXTRACTION=claude-sonnet-4-5
# AI retry policy: transient failures (429/5xx/connection) retried with backoff+jitter.
AI_MAX_RETRIES=3
AI_BASE_RETRY_DELAY_SECONDS=1.0

# JWT / Authentication
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-with-a-real-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Application-level PII encryption (LP-14)
# Fernet key for encrypting sensitive PII (e.g. borrower SSN) at rest. The key
# lives here, never in the database, so a database-only compromise yields only
# ciphertext. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-a-real-fernet-key-44-url-safe-base64-chars=  # pragma: allowlist secret

# CORS
# JSON array of allowed origins
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# File Storage (LP-35)
# Where uploaded document BYTES live (the Document row stores only a storage_path).
# STORAGE_BACKEND selects the backend: "local" (dev) or "s3" (production, Phase 7).
# STORAGE_LOCAL_PATH is the local filesystem root for the "local" backend; it MUST be
# outside any web-served/static directory (files are served only via the auth'd
# download endpoint) and is gitignored — do not commit stored documents.
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# Email (SMTP - points to MailHog in development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mortgageboss.ai
SMTP_FROM_NAME=mortgageboss-ai

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
